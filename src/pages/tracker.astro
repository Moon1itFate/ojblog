---
import HomeSider from '@components/layout/HomeSider.astro';
import OjTrackerApp from '@components/tracker/OjTrackerApp';
import Cover from '@components/ui/cover/Cover.astro';
import { CONTENT_PADDING } from '@constants/layout';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import '@styles/tracker.css';

const title = `刷题追踪 | ${siteConfig.title}`;
const description = '整合公网 OJ 平台提交记录、错题分析、刷题日历与算法比赛追踪。';
---

<Layout title={title} description={description}>
  <TwoColumnLayout>
    <Cover slot="cover" title="刷题追踪" />
    <HomeSider slot="sider" />
    <main class={`tracker-page bg-gradient-start shadow-box ${CONTENT_PADDING.standard}`} data-pagefind-body>
      <div class="mb-5 rounded-lg border border-primary/15 bg-primary/5 px-4 py-3 text-sm text-muted-foreground">
        <p class="mb-2 font-medium text-foreground">刷题追踪模块会持续同步公网 OJ 数据，并逐步沉淀成可复用模板。</p>
        <a class="text-primary transition hover:underline" href="/tracker-guide">查看支持平台、数据边界和新增平台规则</a>
      </div>
      <OjTrackerApp client:load />
    </main>
  </TwoColumnLayout>
</Layout>
